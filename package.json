{
  "name": "android-i18n-mcp",
  "version": "1.0.0",
  "description": "MCP server for automatic Android strings.xml translation",
  "main": "build/index.js",
  "type": "module",
  "scripts": {
    "build": "tsc",
    "dev": "tsx --watch src/index.ts",
    "start": "node build/index.js",
    "test": "node --experimental-vm-modules node_modules/.bin/jest",
    "test:coverage": "node --experimental-vm-modules node_modules/.bin/jest --coverage",
    "test:integration": "node --experimental-vm-modules node_modules/.bin/jest tests/integration/"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.29.0",
    "dotenv": "^16.4.7",
    "fast-xml-parser": "^5.7.2",
    "glob": "^11.0.0",
    "openai": "^4.73.0",
    "simple-git": "^3.27.0",
    "zod": "^3.24.3"
  },
  "devDependencies": {
    "@types/jest": "^30.0.0",
    "@types/node": "^22.10.5",
    "jest": "^30.3.0",
    "ts-jest": "^29.4.9",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2"
  }
}
