# Android-I18N MCP Server Configuration
# NOTE: When running via MCP (mcp_settings.json), these values are overridden.
#
# For local development, use relative paths:
# ANDROID_PROJECT_ROOT=AndroidProject
# For absolute paths:
# ANDROID_PROJECT_ROOT=/path/to/your/android/project
# This file is used when running the server standalone for development/testing.

# Android project root directory
ANDROID_PROJECT_ROOT=/path/to/your/android/project

# Translation provider: 'openai', 'deepseek', 'anthropic', or 'google'
TRANSLATION_PROVIDER=openai

# API key for the translation provider
TRANSLATION_API_KEY=your_api_key_here

# Comma-separated list of languages to translate (optional)
# Supported: zh-CN,zh-TW,zh-SG,zh-HK,zh-MO,en,es,hi,fr,ar,bn,pt,ru,ur,id,de,ja,sw,mr,te,tr,ko,ta,vi,az,be,it,uk
# If not specified, all 28 languages are available (AI can override via MCP call)
# TRANSLATION_LANGUAGES=ru,en

# Optional: Custom API base URL (defaults to provider's standard URL)
# TRANSLATION_API_BASE_URL=https://api.openai.com/v1

# Optional: Model to use (defaults: gpt-4o-mini for OpenAI, deepseek-chat for DeepSeek)
# TRANSLATION_MODEL=gpt-4o-mini

# Logging configuration (optional)
# Set to 'true' to enable file logging to logs/mcp-errors.log
# When false (default), logs go to stderr only
# LOG_TO_FILE=true